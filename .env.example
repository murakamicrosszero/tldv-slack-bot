# TLDVのWebhookシークレット（TLDVの設定画面からコピー）
TLDV_WEBHOOK_SECRET=your_tldv_webhook_secret_here

# Anthropic APIキー（https://console.anthropic.com から取得）
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# SlackのIncoming Webhook URL（Slack Appの設定画面から取得）
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/your/webhook/url

# サーバーのポート番号（Railway環境では自動設定されるため通常変更不要）
PORT=3000
