# TLDVのWebhook APIキー（サーバー側で設定した任意のキー）
TLDV_API_KEY=your_tldv_api_key_here

# TLDV APIキー（TLDV Settings → API Keys から取得）
# トランスクリプトの準備完了確認に使用
TLDV_API_ACCESS_KEY=your_tldv_api_access_key_here

# Anthropic APIキー（https://console.anthropic.com から取得）
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# SlackのIncoming Webhook URL（Slack Appの設定画面から取得）
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/your/webhook/url

# サーバーのポート番号（Railway環境では自動設定されるため通常変更不要）
PORT=3000
